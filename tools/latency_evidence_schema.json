{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openboa.dev/schemas/latency-evidence-record-v1.json",
  "title": "OpenBOA Queue Latency Evidence Record",
  "type": "object",
  "required": ["task_id", "task_enqueued_at", "first_worker_ack_at"],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "task_enqueued_at": {
      "type": "string",
      "format": "date-time"
    },
    "first_worker_ack_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
