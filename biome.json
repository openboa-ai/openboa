{
  "$schema": "https://biomejs.dev/schemas/2.4.2/schema.json",
  "files": {
    "ignoreUnknown": true,
    "ignore": ["dist/**", "coverage/**", "node_modules/**"],
    "include": [
      "src/**",
      "test/**",
      "scripts/**",
      "docs/**/*.md",
      "*.ts",
      "*.js",
      "*.md",
      "*.json",
      "package.json",
      "biome.json",
      "tsconfig.json",
      "pnpm-lock.yaml",
      ".pre-commit-config.yaml"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "asNeeded"
    }
  }
}
